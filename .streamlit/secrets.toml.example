# Copy this file to .streamlit/secrets.toml for local development.
# On Streamlit Cloud, set these values in the app settings UI.
# NEVER commit secrets.toml to git.

[aws]
access_key_id     = "YOUR_AWS_ACCESS_KEY_ID"
secret_access_key = "YOUR_AWS_SECRET_ACCESS_KEY"
region            = "us-east-1"

[opensearch]
endpoint = "https://YOUR-COLLECTION-ID.us-east-1.aoss.amazonaws.com"
