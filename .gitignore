# ============================================
# TERRAFORM
# ============================================

# Local terraform state
*.tfstate
*.tfstate.*
crash.log
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl

# Sensitive variable files
*.tfvars
*.tfvars.json

# ============================================
# PROJECT DATA (DO NOT COMMIT RAW DATA)
# ============================================

data/
data/*
data/*/*
!data/.gitkeep

# NOAA / FEMA / NRI / Census raw dumps
**/data/raw/**

# Large intermediate files
*.parquet
*.csv
*.tsv
*.jsonl
*.zip

